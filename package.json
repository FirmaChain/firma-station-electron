{
  "name": "firma-station-electron",
  "version": "1.1.0-beta.1",
  "license": "ISC",
  "homepage": "./",
  "description": "A desktop application to interact with FIRMACHAIN.",
  "author": "FIRMACHAIN <developer@firmachain.org> (https://firmachain.org)",
  "main": "public/electron.js",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^23.6.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@firmachain/firma-js": "github:firmachain/firma-js#v0.4.2",
    "@ledgerhq/hw-transport-node-hid": "^6.33.1",
    "electron-debug": "^3.2.0"
  },
  "scripts": {
    "compile": "tsc",
    "dev": "tsc && electron public/electron.js",
    "build": "tsc && electron-builder build --publish never"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.firmachain.station",
    "productName": "Firma Station",
    "copyright": "Copyright © 2021 FirmaChain",
    "artifactName": "${productName}-${os}-${arch}-${version}.${ext}",
    "asar": true,
    "extends": null,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.icns"
    },
    "mac": {
      "category": "public.app-category.financial",
      "target": {
        "target": "default",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "Firma Station",
      "window": {
        "width": 540,
        "height": 370
      },
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "installerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true
    }
  }
}
